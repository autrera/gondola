VENICE_API_KEY=your_venice_inference_key

# Alternative provider: Surplus Intelligence (GLM 5.2, DeepSeek v4, Grok 4.5).
# Set this instead of VENICE_API_KEY to use Surplus as your inference provider.
# SURPLUS_API_KEY=your_surplus_api_key

# Optional. Admin-scoped key used for billing/usage endpoints shown in the API
# x-ray (account balance, usage analytics). Server-only. Falls back to
# VENICE_API_KEY when unset.
# VENICE_ADMIN_KEY=your_venice_admin_key

# Optional. Enables the Telegram channel (Automations tab) without storing the
# token in .gondola. You can also paste the token directly in the Automations UI.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token

# Optional. Web server host and port (defaults: localhost and 3000).
# PORT=3000
# HOST=localhost

